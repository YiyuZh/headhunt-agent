# Runtime
APP_ENV=docker
APP_NAME=AI Headhunter Feishu War Room
APP_VERSION=0.1.0
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443
DATABASE_WAIT_SECONDS=60
INTERNAL_ADMIN_API_KEY=change-this-admin-key

# Docker Compose PostgreSQL service
POSTGRES_DB=lietou
POSTGRES_USER=lietou
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=5432
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

# PostgreSQL main path:
# - Docker Compose derives DATABASE_URL and CHECKPOINT_DB_URL from POSTGRES_* by default.
# - For an external database in containers, change POSTGRES_HOST/POSTGRES_INTERNAL_PORT/user/password/db.
# - Only set DATABASE_URL manually for a host-local Python run.
# DATABASE_URL=postgresql+psycopg://lietou:change-this-password@postgres:5432/lietou
# CHECKPOINT_DB_URL=postgresql+psycopg://lietou:change-this-password@postgres:5432/lietou

# Vector memory
VECTOR_STORE_PROVIDER=pgvector
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# Optional local embedding fallback. Feishu users should add embedding profiles later.
EMBEDDING_API_KEY=

# Discord optional adapter
CHANNEL_GATEWAY_PROVIDER=feishu
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_API_BASE_URL=https://discord.com/api/v10
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_INTERACTION_CALLBACK_PATH=/discord/interactions
DISCORD_COMMAND_REGISTER_GUILD_ID=
DISCORD_SIGNATURE_MAX_AGE_SECONDS=300
DISCORD_INTERACTION_ACK_TIMEOUT_SECONDS=3
DISCORD_OUTBOX_MAX_ATTEMPTS=5

# SOP and memory governance
SOP_REGISTRY_PATH=docs/agent-sops
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_MAX_TOKENS_PER_AGENT=800
MEMORY_RUN_RETENTION_DAYS=30
MEMORY_LONG_RETENTION_DAYS=90
CONTEXT_PACK_MAX_TOKENS=3000

# Feishu BYOK model profiles
# Business chat/reasoning models are not selected here. Feishu users add their own
# OpenAI/DeepSeek API key and model name through Feishu model profile cards; this key encrypts those
# user-owned API keys at rest.
MODEL_SECRET_ENCRYPTION_KEY=change-this-32-byte-or-base64-secret
MODEL_PROVIDER_ALLOWLIST=openai,deepseek

# Feishu first workspace
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_DEFAULT_CHAT_ID=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_REQUISITION_TABLE_ID=
FEISHU_BITABLE_CANDIDATE_TABLE_ID=
FEISHU_BITABLE_TALENT_MAP_TABLE_ID=
FEISHU_BITABLE_REPORT_TABLE_ID=

# Legacy local debug fallback only, not the Feishu multi-user main path.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high

# Worker
OUTBOX_WORKER_ID=
OUTBOX_POLL_SECONDS=2
